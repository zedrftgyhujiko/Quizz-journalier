name: Quiz quotidien Anesthésie-Réanimation

on:
  schedule:
    - cron: "0 5 * * *"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  send-quiz:
    runs-on: ubuntu-latest
    steps:
      - name: Récupérer le code
        uses: actions/checkout@v4

      - name: Configurer Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Générer le quiz HTML
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          NTFY_TOPIC: ${{ secrets.NTFY_TOPIC }}
          PAGES_URL: ${{ secrets.PAGES_URL }}
        run: node generate-quiz.js

      - name: Publier sur GitHub Pages
        run: |
          git config user.name "Quiz Bot"
          git config user.email "quiz-bot@ar.fr"
          git add docs/index.html
          git diff --staged --quiet || git commit -m "Quiz du jour $(date +%Y-%m-%d)"
          git push
