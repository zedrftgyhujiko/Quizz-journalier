name: Quiz quotidien Anesthésie-Réanimation

on:
  schedule:
    - cron: "0 5 * * *"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  send-quiz:
    runs-on: ubuntu-latest
    steps:
      - name: Récupérer le code
        uses: actions/checkout@v4

      - name: Configurer Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"

      - name: Générer le quiz HTML
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: node generate-quiz.js

      - name: Publier le fichier sur GitHub
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "Quiz du jour"
          file_pattern: docs/index.html

      - name: Envoyer la notification
        env:
          NTFY_TOPIC: ${{ secrets.NTFY_TOPIC }}
        run: node send-notif.js
